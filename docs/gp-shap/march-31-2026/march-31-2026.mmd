    TrainGBM --> SHAPCalc["shap.TreeExplainer -> shap_values"]
    Predict --> Assemble["Assemble JSON: historical, forecast, gp_full"]
    SHAPCalc --> Assemble
    Assemble --> Return["Return dict with means, intervals, SHAP feature breakdowns"]
